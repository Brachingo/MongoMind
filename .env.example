# Ollama — modelo local (instalar desde https://ollama.com y `ollama pull llama3.2`)
OLLAMA_MODEL=llama3.2
# Host de Ollama. En local no hace falta (usa 127.0.0.1:11434 por defecto).
# En Docker, el compose lo fija a host.docker.internal para alcanzar el Ollama del host.
# OLLAMA_HOST=http://host.docker.internal:11434

# MongoDB Atlas — cadena de conexión (Atlas → Connect → Drivers)
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=sample_mflix

# App
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
