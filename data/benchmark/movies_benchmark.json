{
  "collection": "movies",
  "database": "sample_mflix",
  "description": "Benchmark NL->MQL para la colección movies de sample_mflix. Cada par tiene la pregunta en lenguaje natural y la query MQL de referencia (ejecutable). La evaluación es por corrección funcional: se ejecutan ambas queries y se comparan resultados.",
  "split_policy": "70% dev / 30% test. El split de test NO debe usarse para ajustar prompts ni few-shots.",
  "complexity_counts": { "simple": 20, "media": 25, "alta": 15, "ambiguous": 5 },
  "lang_counts": { "es": 32, "en": 33 },
  "result_types": ["documents", "count", "scalar", "groups"],
  "pairs": [
    { "id": "s01", "lang": "en", "complexity": "simple", "category": "filter", "result_type": "documents", "split": "dev",
      "question": "Find the movie titled Inception", "expected_mql": {"title": "Inception"} },
    { "id": "s02", "lang": "es", "complexity": "simple", "category": "filter", "result_type": "documents", "split": "dev",
      "question": "Películas del género Action", "expected_mql": {"genres": "Action"} },
    { "id": "s03", "lang": "en", "complexity": "simple", "category": "filter", "result_type": "documents", "split": "test",
      "question": "Movies directed by Christopher Nolan", "expected_mql": {"directors": "Christopher Nolan"} },
    { "id": "s04", "lang": "es", "complexity": "simple", "category": "filter", "result_type": "documents", "split": "dev",
      "question": "Películas en las que actúa Tom Hanks", "expected_mql": {"cast": "Tom Hanks"} },
    { "id": "s05", "lang": "en", "complexity": "simple", "category": "filter", "result_type": "documents", "split": "dev",
      "question": "Movies released in 1994", "expected_mql": {"year": 1994} },
    { "id": "s06", "lang": "es", "complexity": "simple", "category": "filter", "result_type": "documents", "split": "dev",
      "question": "Películas clasificadas como PG-13", "expected_mql": {"rated": "PG-13"} },
    { "id": "s07", "lang": "en", "complexity": "simple", "category": "filter", "result_type": "documents", "split": "test",
      "question": "Movies from the USA", "expected_mql": {"countries": "USA"} },
    { "id": "s08", "lang": "es", "complexity": "simple", "category": "filter", "result_type": "documents", "split": "dev",
      "question": "Películas en español", "expected_mql": {"languages": "Spanish"} },
    { "id": "s09", "lang": "en", "complexity": "simple", "category": "filter", "result_type": "documents", "split": "dev",
      "question": "Find all series", "expected_mql": {"type": "series"} },
    { "id": "s10", "lang": "en", "complexity": "simple", "category": "filter", "result_type": "documents", "split": "dev",
      "question": "Comedy movies released in 2010", "expected_mql": {"genres": "Comedy", "year": 2010} },
    { "id": "s11", "lang": "es", "complexity": "simple", "category": "filter", "result_type": "documents", "split": "dev",
      "question": "Películas dirigidas por Steven Spielberg", "expected_mql": {"directors": "Steven Spielberg"} },
    { "id": "s12", "lang": "es", "complexity": "simple", "category": "filter", "result_type": "documents", "split": "test",
      "question": "Películas de terror", "expected_mql": {"genres": "Horror"} },
    { "id": "s13", "lang": "en", "complexity": "simple", "category": "filter", "result_type": "documents", "split": "dev",
      "question": "Find the movie titled Titanic", "expected_mql": {"title": "Titanic"} },
    { "id": "s14", "lang": "en", "complexity": "simple", "category": "filter", "result_type": "documents", "split": "dev",
      "question": "Movies starring Leonardo DiCaprio", "expected_mql": {"cast": "Leonardo DiCaprio"} },
    { "id": "s15", "lang": "es", "complexity": "simple", "category": "filter", "result_type": "documents", "split": "dev",
      "question": "Películas del año 2000", "expected_mql": {"year": 2000} },
    { "id": "s16", "lang": "es", "complexity": "simple", "category": "filter", "result_type": "documents", "split": "test",
      "question": "Películas clasificadas R del género Crime", "expected_mql": {"rated": "R", "genres": "Crime"} },
    { "id": "s17", "lang": "en", "complexity": "simple", "category": "filter", "result_type": "documents", "split": "dev",
      "question": "Movies in French", "expected_mql": {"languages": "French"} },
    { "id": "s18", "lang": "en", "complexity": "simple", "category": "filter", "result_type": "documents", "split": "dev",
      "question": "Documentary movies", "expected_mql": {"genres": "Documentary"} },
    { "id": "s19", "lang": "es", "complexity": "simple", "category": "filter", "result_type": "documents", "split": "test",
      "question": "Películas dirigidas por Quentin Tarantino", "expected_mql": {"directors": "Quentin Tarantino"} },
    { "id": "s20", "lang": "es", "complexity": "simple", "category": "filter", "result_type": "documents", "split": "dev",
      "question": "Películas de Reino Unido del género Drama", "expected_mql": {"countries": "UK", "genres": "Drama"} },

    { "id": "m01", "lang": "en", "complexity": "media", "category": "comparison", "result_type": "documents", "split": "dev",
      "question": "Movies with an IMDb rating above 8.5", "expected_mql": {"imdb.rating": {"$gt": 8.5}} },
    { "id": "m02", "lang": "en", "complexity": "media", "category": "comparison", "result_type": "documents", "split": "test",
      "question": "Find movies with runtime greater than 180 minutes", "expected_mql": {"runtime": {"$gt": 180}} },
    { "id": "m03", "lang": "en", "complexity": "media", "category": "comparison", "result_type": "documents", "split": "dev",
      "question": "Movies released after 2010", "expected_mql": {"year": {"$gt": 2010}} },
    { "id": "m04", "lang": "es", "complexity": "media", "category": "range", "result_type": "documents", "split": "dev",
      "question": "Películas estrenadas entre 2000 y 2010", "expected_mql": {"year": {"$gte": 2000, "$lte": 2010}} },
    { "id": "m05", "lang": "en", "complexity": "media", "category": "comparison", "result_type": "documents", "split": "dev",
      "question": "Movies with more than one million votes on IMDb", "expected_mql": {"imdb.votes": {"$gt": 1000000}} },
    { "id": "m06", "lang": "en", "complexity": "media", "category": "in", "result_type": "documents", "split": "dev",
      "question": "Movies directed by Christopher Nolan or Steven Spielberg", "expected_mql": {"directors": {"$in": ["Christopher Nolan", "Steven Spielberg"]}} },
    { "id": "m07", "lang": "es", "complexity": "media", "category": "in", "result_type": "documents", "split": "dev",
      "question": "Películas de género Drama o Thriller", "expected_mql": {"genres": {"$in": ["Drama", "Thriller"]}} },
    { "id": "m08", "lang": "en", "complexity": "media", "category": "regex", "result_type": "documents", "split": "test",
      "question": "Movies whose title contains the word love", "expected_mql": {"title": {"$regex": "love", "$options": "i"}} },
    { "id": "m09", "lang": "en", "complexity": "media", "category": "regex", "result_type": "documents", "split": "dev",
      "question": "Movies whose title starts with The", "expected_mql": {"title": {"$regex": "^The", "$options": "i"}} },
    { "id": "m10", "lang": "es", "complexity": "media", "category": "sort_limit", "result_type": "documents", "split": "dev",
      "question": "Las 10 películas con mayor puntuación IMDb", "expected_mql": [{"$match": {"imdb.rating": {"$type": "number"}}}, {"$sort": {"imdb.rating": -1}}, {"$limit": 10}, {"$project": {"title": 1, "imdb.rating": 1, "year": 1, "_id": 0}}] },
    { "id": "m11", "lang": "en", "complexity": "media", "category": "sort_limit", "result_type": "documents", "split": "dev",
      "question": "The 5 longest movies", "expected_mql": [{"$match": {"runtime": {"$type": "number"}}}, {"$sort": {"runtime": -1}}, {"$limit": 5}, {"$project": {"title": 1, "runtime": 1, "_id": 0}}] },
    { "id": "m12", "lang": "en", "complexity": "media", "category": "sort_limit", "result_type": "documents", "split": "test",
      "question": "The 5 most recent movies", "expected_mql": [{"$match": {"year": {"$type": "number"}}}, {"$sort": {"year": -1}}, {"$limit": 5}, {"$project": {"title": 1, "year": 1, "_id": 0}}] },
    { "id": "m13", "lang": "en", "complexity": "media", "category": "comparison", "result_type": "documents", "split": "dev",
      "question": "Action movies with an IMDb rating greater than 8", "expected_mql": {"genres": "Action", "imdb.rating": {"$gt": 8}} },
    { "id": "m14", "lang": "es", "complexity": "media", "category": "comparison", "result_type": "documents", "split": "dev",
      "question": "Películas que ganaron más de 5 premios", "expected_mql": {"awards.wins": {"$gt": 5}} },
    { "id": "m15", "lang": "es", "complexity": "media", "category": "range", "result_type": "documents", "split": "dev",
      "question": "Películas con puntuación IMDb entre 7 y 8", "expected_mql": {"imdb.rating": {"$gte": 7, "$lte": 8}} },
    { "id": "m16", "lang": "es", "complexity": "media", "category": "count", "result_type": "count", "split": "test",
      "question": "¿Cuántas películas hay de género Comedy?", "expected_mql": [{"$match": {"genres": "Comedy"}}, {"$count": "total"}] },
    { "id": "m17", "lang": "es", "complexity": "media", "category": "count", "result_type": "count", "split": "dev",
      "question": "¿Cuántas películas se estrenaron en 2015?", "expected_mql": [{"$match": {"year": 2015}}, {"$count": "total"}] },
    { "id": "m18", "lang": "en", "complexity": "media", "category": "avg", "result_type": "scalar", "split": "dev",
      "question": "What is the average runtime of the movies?", "expected_mql": [{"$match": {"runtime": {"$type": "number"}}}, {"$group": {"_id": null, "duracion_media": {"$avg": "$runtime"}}}] },
    { "id": "m19", "lang": "es", "complexity": "media", "category": "group", "result_type": "groups", "split": "test",
      "question": "¿Cuántas películas hay de cada clasificación?", "expected_mql": [{"$group": {"_id": "$rated", "total": {"$sum": 1}}}, {"$sort": {"total": -1}}] },
    { "id": "m20", "lang": "en", "complexity": "media", "category": "comparison", "result_type": "documents", "split": "dev",
      "question": "Movies starring Tom Hanks that won more than 3 awards", "expected_mql": {"cast": "Tom Hanks", "awards.wins": {"$gt": 3}} },
    { "id": "m21", "lang": "es", "complexity": "media", "category": "comparison", "result_type": "documents", "split": "dev",
      "question": "Películas con puntuación de audiencia en Rotten Tomatoes mayor de 4", "expected_mql": {"tomatoes.viewer.rating": {"$gt": 4}} },
    { "id": "m22", "lang": "en", "complexity": "media", "category": "comparison", "result_type": "documents", "split": "test",
      "question": "Sci-Fi movies released after 2000", "expected_mql": {"genres": "Sci-Fi", "year": {"$gt": 2000}} },
    { "id": "m23", "lang": "es", "complexity": "media", "category": "ne", "result_type": "documents", "split": "dev",
      "question": "Películas que no son del género Drama", "expected_mql": {"genres": {"$ne": "Drama"}} },
    { "id": "m24", "lang": "es", "complexity": "media", "category": "comparison", "result_type": "documents", "split": "dev",
      "question": "Películas con más de 10 nominaciones", "expected_mql": {"awards.nominations": {"$gt": 10}} },
    { "id": "m25", "lang": "es", "complexity": "media", "category": "sort_limit", "result_type": "documents", "split": "test",
      "question": "Las 10 películas con más premios ganados", "expected_mql": [{"$match": {"awards.wins": {"$type": "number"}}}, {"$sort": {"awards.wins": -1}}, {"$limit": 10}, {"$project": {"title": 1, "awards.wins": 1, "_id": 0}}] },

    { "id": "a01", "lang": "en", "complexity": "alta", "category": "unwind_group", "result_type": "groups", "split": "dev",
      "question": "How many movies are there of each genre?", "expected_mql": [{"$unwind": "$genres"}, {"$group": {"_id": "$genres", "total": {"$sum": 1}}}, {"$sort": {"total": -1}}] },
    { "id": "a02", "lang": "es", "complexity": "alta", "category": "unwind_group", "result_type": "groups", "split": "test",
      "question": "Los 5 directores con más películas", "expected_mql": [{"$unwind": "$directors"}, {"$group": {"_id": "$directors", "num_peliculas": {"$sum": 1}}}, {"$sort": {"num_peliculas": -1}}, {"$limit": 5}] },
    { "id": "a03", "lang": "en", "complexity": "alta", "category": "unwind_group", "result_type": "groups", "split": "dev",
      "question": "Average IMDb rating by genre", "expected_mql": [{"$match": {"imdb.rating": {"$type": "number"}}}, {"$unwind": "$genres"}, {"$group": {"_id": "$genres", "rating_medio": {"$avg": "$imdb.rating"}}}, {"$sort": {"rating_medio": -1}}] },
    { "id": "a04", "lang": "es", "complexity": "alta", "category": "multi", "result_type": "documents", "split": "dev",
      "question": "Películas de Drama o Thriller con IMDb entre 7 y 9 estrenadas entre 2000 y 2015", "expected_mql": [{"$match": {"genres": {"$in": ["Drama", "Thriller"]}, "imdb.rating": {"$gte": 7, "$lte": 9}, "year": {"$gte": 2000, "$lte": 2015}}}, {"$project": {"title": 1, "genres": 1, "imdb.rating": 1, "year": 1, "_id": 0}}, {"$sort": {"imdb.rating": -1}}] },
    { "id": "a05", "lang": "en", "complexity": "alta", "category": "lookup", "result_type": "documents", "split": "test",
      "question": "How many comments does the movie The Dark Knight have?", "expected_mql": [{"$match": {"title": "The Dark Knight"}}, {"$lookup": {"from": "comments", "localField": "_id", "foreignField": "movie_id", "as": "comentarios"}}, {"$project": {"title": 1, "num_comentarios": {"$size": "$comentarios"}, "_id": 0}}] },
    { "id": "a06", "lang": "en", "complexity": "alta", "category": "group", "result_type": "groups", "split": "dev",
      "question": "Number of movies released per year", "expected_mql": [{"$match": {"year": {"$type": "number"}}}, {"$group": {"_id": "$year", "total": {"$sum": 1}}}, {"$sort": {"_id": 1}}] },
    { "id": "a07", "lang": "en", "complexity": "alta", "category": "unwind_group", "result_type": "groups", "split": "dev",
      "question": "The 10 actors appearing in the most movies", "expected_mql": [{"$unwind": "$cast"}, {"$group": {"_id": "$cast", "num_peliculas": {"$sum": 1}}}, {"$sort": {"num_peliculas": -1}}, {"$limit": 10}] },
    { "id": "a08", "lang": "es", "complexity": "alta", "category": "unwind_group", "result_type": "groups", "split": "dev",
      "question": "Duración media de las películas por clasificación", "expected_mql": [{"$match": {"runtime": {"$type": "number"}}}, {"$group": {"_id": "$rated", "duracion_media": {"$avg": "$runtime"}}}, {"$sort": {"duracion_media": -1}}] },
    { "id": "a09", "lang": "es", "complexity": "alta", "category": "array_all", "result_type": "documents", "split": "test",
      "question": "Películas que son a la vez de Action y Adventure", "expected_mql": {"genres": {"$all": ["Action", "Adventure"]}} },
    { "id": "a10", "lang": "en", "complexity": "alta", "category": "unwind_group", "result_type": "groups", "split": "dev",
      "question": "Top 5 genres with the highest average IMDb rating", "expected_mql": [{"$match": {"imdb.rating": {"$type": "number"}}}, {"$unwind": "$genres"}, {"$group": {"_id": "$genres", "rating_medio": {"$avg": "$imdb.rating"}, "num": {"$sum": 1}}}, {"$sort": {"rating_medio": -1}}, {"$limit": 5}] },
    { "id": "a11", "lang": "es", "complexity": "alta", "category": "array_size", "result_type": "documents", "split": "dev",
      "question": "Películas con un reparto de más de 3 actores", "expected_mql": {"cast.3": {"$exists": true}} },
    { "id": "a12", "lang": "en", "complexity": "alta", "category": "array_all", "result_type": "documents", "split": "dev",
      "question": "Movies featuring both Brad Pitt and George Clooney", "expected_mql": {"cast": {"$all": ["Brad Pitt", "George Clooney"]}} },
    { "id": "a13", "lang": "es", "complexity": "alta", "category": "sum", "result_type": "scalar", "split": "test",
      "question": "Número total de premios ganados por las películas de Christopher Nolan", "expected_mql": [{"$match": {"directors": "Christopher Nolan"}}, {"$group": {"_id": null, "total_premios": {"$sum": "$awards.wins"}}}] },
    { "id": "a14", "lang": "en", "complexity": "alta", "category": "sort_limit", "result_type": "documents", "split": "test",
      "question": "The 5 best rated movies by critics on Rotten Tomatoes", "expected_mql": [{"$match": {"tomatoes.critic.rating": {"$type": "number"}}}, {"$sort": {"tomatoes.critic.rating": -1}}, {"$limit": 5}, {"$project": {"title": 1, "tomatoes.critic.rating": 1, "_id": 0}}] },
    { "id": "a15", "lang": "es", "complexity": "alta", "category": "multi", "result_type": "documents", "split": "dev",
      "question": "Películas de comedia de menos de 90 minutos con puntuación IMDb mayor de 7", "expected_mql": [{"$match": {"genres": "Comedy", "runtime": {"$lt": 90}, "imdb.rating": {"$gt": 7}}}, {"$project": {"title": 1, "runtime": 1, "imdb.rating": 1, "_id": 0}}, {"$sort": {"imdb.rating": -1}}] },

    { "id": "x01", "lang": "en", "complexity": "ambiguous", "category": "typo", "result_type": "documents", "split": "dev",
      "question": "action moovies from 2010", "expected_mql": {"genres": "Action", "year": 2010} },
    { "id": "x02", "lang": "es", "complexity": "ambiguous", "category": "typo", "result_type": "count", "split": "test",
      "question": "cuantas peliculas dirijio Tarantino?", "expected_mql": [{"$match": {"directors": "Quentin Tarantino"}}, {"$count": "total"}] },
    { "id": "x03", "lang": "es", "complexity": "ambiguous", "category": "ambiguous", "result_type": "documents", "split": "dev",
      "question": "las mejores películas", "expected_mql": [{"$match": {"imdb.rating": {"$type": "number"}}}, {"$sort": {"imdb.rating": -1}}, {"$limit": 10}, {"$project": {"title": 1, "imdb.rating": 1, "_id": 0}}] },
    { "id": "x04", "lang": "en", "complexity": "ambiguous", "category": "typo", "result_type": "documents", "split": "test",
      "question": "recent horrror movies", "expected_mql": {"genres": "Horror", "year": {"$gte": 2010}} },
    { "id": "x05", "lang": "es", "complexity": "ambiguous", "category": "ambiguous", "result_type": "documents", "split": "dev",
      "question": "películas largas", "expected_mql": {"runtime": {"$gt": 150}} }
  ]
}
