{
  "collection": "movies",
  "description": "Películas y series de la base de datos sample_mflix de MongoDB Atlas.",
  "fields": {
    "title":               { "type": "string",   "example": "The Dark Knight" },
    "plot":                { "type": "string",   "example": "When the menace known as the Joker wreaks havoc..." },
    "fullplot":            { "type": "string",   "example": "Texto largo con el argumento completo" },
    "genres":              { "type": "array<string>", "example": ["Action", "Crime", "Drama"], "values": ["Action","Adventure","Animation","Biography","Comedy","Crime","Documentary","Drama","Family","Fantasy","Film-Noir","History","Horror","Music","Musical","Mystery","Romance","Sci-Fi","Short","Sport","Thriller","War","Western"] },
    "cast":                { "type": "array<string>", "example": ["Christian Bale", "Heath Ledger"] },
    "directors":           { "type": "array<string>", "example": ["Christopher Nolan"] },
    "countries":           { "type": "array<string>", "example": ["USA", "UK"] },
    "languages":           { "type": "array<string>", "example": ["English"] },
    "year":                { "type": "integer",  "example": 2008 },
    "runtime":             { "type": "integer",  "example": 152, "unit": "minutes" },
    "rated":               { "type": "string",   "example": "PG-13", "values": ["G","PG","PG-13","R","TV-14","TV-MA","TV-PG","Not Rated"] },
    "type":                { "type": "string",   "example": "movie", "values": ["movie", "series"] },
    "released":            { "type": "date",     "example": "2008-07-18T00:00:00Z" },
    "poster":              { "type": "string",   "example": "https://..." },
    "lastupdated":         { "type": "string",   "example": "2015-09-01 00:22:54.280000000" },
    "num_mflix_comments":  { "type": "integer",  "example": 4 },
    "imdb": {
      "type": "object",
      "fields": {
        "rating": { "type": "float",   "example": 9.0 },
        "votes":  { "type": "integer", "example": 2026578 },
        "id":     { "type": "integer", "example": 468569 }
      }
    },
    "awards": {
      "type": "object",
      "fields": {
        "wins":        { "type": "integer", "example": 2 },
        "nominations": { "type": "integer", "example": 4 },
        "text":        { "type": "string",  "example": "2 wins & 4 nominations." }
      }
    },
    "tomatoes": {
      "type": "object",
      "fields": {
        "viewer":  { "type": "object", "fields": { "rating": { "type": "float" }, "numReviews": { "type": "integer" }, "meter": { "type": "integer" } } },
        "critic":  { "type": "object", "fields": { "rating": { "type": "float" }, "numReviews": { "type": "integer" }, "meter": { "type": "integer" } } },
        "fresh":   { "type": "integer" },
        "rotten":  { "type": "integer" }
      }
    }
  },
  "related_collections": {
    "comments": "Comentarios de usuarios. Cada comentario tiene movie_id (ObjectId) que referencia movies._id."
  }
}
